    if text == "/getkey" and chat_id == ADMIN_ID:
        keys = load_keys()
        for k, v in keys.items():
            if (not v.get("is_use", False)
                and not v.get("banned", False)
                and not v.get("issued", False)):

                v["issued"] = True
                save_keys(keys)

                bot.sendMessage(chat_id, k)
                return "OK", 200

        bot.sendMessage(chat_id, "Свободных ключей нет.")
        return "OK", 200


    # команда /ban <ключ>
    if text.startswith("/ban ") and chat_id == ADMIN_ID:
        _, key = text.split(maxsplit=1)
        key = key.upper()
        keys = load_keys()
        if key in keys:
            keys[key]["banned"] = True
            save_keys(keys)
            bot.sendMessage(chat_id, f"Ключ {key} забанен.")
        else:
            bot.sendMessage(chat_id, "Ключ не найден.")
        return "OK", 200

    # команда /quantity
    if text == "/quantity" and chat_id == ADMIN_ID:
        keys = load_keys()
        total = len(keys)
        free  = sum(1 for v in keys.values() if not v.get("is_use", False) and not v.get("banned", False))
        used  = total - free
        bot.sendMessage(chat_id, f"Всего: {total}, свободно: {free}, использовано: {used}")
        return "OK", 200

    return "OK", 200
