from flask import Flask, request, jsonify
import json
import telepot
import urllib3

KEYS_FILE = "/home/arle/keys.json"
SECRET = "my_bot_webhook_path_123"

proxy_url = "http://proxy.server:3128"
telepot.api._pools = {
    'default': urllib3.ProxyManager(proxy_url=proxy_url),
}

bot = telepot.Bot(TOKEN)
app = Flask(__name__)

def load_keys():
    with open(KEYS_FILE, encoding="utf-8") as f:
        return json.load(f)

def save_keys(data):
    with open(KEYS_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

from datetime import datetime

@app.route("/check", methods=["GET"])
def check():
    key  = request.args.get("key", "").upper()
    hwid = request.args.get("hwid", "").lower()

    if not key or not hwid:
        return jsonify(status="error")

    keys = load_keys()

    if key not in keys:
        return jsonify(status="not_found")

    record = keys[key]

    # Сначала бан
    if record.get("banned", False):
        return jsonify(status="banned")

    # Потом проверка — был ли выдан ботом
    if not record.get("issued", False):
        return jsonify(status="not_issued")

    # Если ключ ещё не использовался — привязываем HWID
    if not record.get("is_use", False):
        record["is_use"] = True
        record["hwid"] = hwid
        record["used_at"] = datetime.utcnow().isoformat()
        save_keys(keys)
        return jsonify(status="ok")

    # Если уже использовался — проверяем HWID
    if record.get("hwid") == hwid:
        return jsonify(status="ok")
    else:
        return jsonify(status="used")


